        <mxCell id="note" value="Timecode is copied into the slot and re-emitted unchanged — the correlation key that makes frame-exactness measurable (Airlock.ScteGen / Airlock.ScteProbe)" style="text;html=1;fontSize=10;fontStyle=2;align=left;fillColor=#f5f5f5;strokeColor=#999999;rounded=1;verticalAlign=middle;spacing=6;" vertex="1" parent="1">
