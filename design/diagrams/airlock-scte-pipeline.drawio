          <mxGeometry x="730" y="240" width="170" height="20" as="geometry"/>
        </mxCell>
        <mxCell id="e8" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;dashed=1;strokeColor=#b85450;exitX=0.75;exitY=1;entryX=0.5;entryY=0;" edge="1" parent="1" source="gate" target="ring">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>
        <mxCell id="e8l" value="cue airs → trigger record&#xa;(event id · aired frame index · upstream P)" style="text;html=1;fontSize=10;fontStyle=2;align=left;" vertex="1" parent="1">
          <mxGeometry x="1120" y="230" width="250" height="30" as="geometry"/>
        </mxCell>
        <mxCell id="e9" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;" edge="1" parent="1" source="ring" target="appsrc"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="e10" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;" edge="1" parent="1" source="appsrc" target="x264"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="e11" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;" edge="1" parent="1" source="x264" target="mux"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="e12" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;" edge="1" parent="1" source="mux" target="srt"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="e13" value="send_event" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;dashed=1;strokeColor=#b85450;fontSize=10;exitX=1;exitY=0.5;entryX=0.5;entryY=1;" edge="1" parent="1" source="scte35" target="mux">
