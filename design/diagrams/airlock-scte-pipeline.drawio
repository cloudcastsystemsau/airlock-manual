<mxfile host="app.diagrams.net" modified="2026-07-13T00:00:00.000Z" agent="Claude" version="26.2.2" type="device">
  <diagram name="SCTE pipeline" id="airlock-scte-pipeline">
    <mxGraphModel dx="1200" dy="800" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1440" pageHeight="620" math="0" shadow="0">
      <root>
        <mxCell id="0"/>
        <mxCell id="1" parent="0"/>

        <mxCell id="title" value="Airlock SCTE path — one engine thread delays pictures and cues together; the encode child splices the TS to the same instant" style="text;html=1;fontSize=16;fontStyle=1;align=center;verticalAlign=middle;" vertex="1" parent="1">
          <mxGeometry x="220" y="16" width="1000" height="34" as="geometry"/>
        </mxCell>

        <mxCell id="lane1" value="NDI delay engine — single thread, zero-alloc after start (NFR-04)" style="text;html=1;fontSize=11;fontStyle=2;align=left;" vertex="1" parent="1">
          <mxGeometry x="40" y="70" width="520" height="20" as="geometry"/>
        </mxCell>

        <mxCell id="src" value="NDI source&#xa;SCTE-104 in VANC&#xa;(vancData XML)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="40" y="110" width="170" height="70" as="geometry"/>
        </mxCell>

        <mxCell id="recv" value="recv" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="260" y="120" width="90" height="50" as="geometry"/>
        </mxCell>

        <mxCell id="slot" value="FramePool slot&#xa;video · audio · timecode&#xa;+ 4 KB metadata region&#xa;(the SCTE-104 rides the slot)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=11;fontStyle=1" vertex="1" parent="1">
          <mxGeometry x="400" y="100" width="220" height="90" as="geometry"/>
        </mxCell>

        <mxCell id="fifo" value="DelayFifo&#xa;N slots = depth&#xa;(BUILD grows · DUMP jumps)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="670" y="110" width="190" height="70" as="geometry"/>
        </mxCell>

        <mxCell id="pacer" value="deadline pacer&#xa;20 ms @ 50 fps" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="910" y="120" width="130" height="50" as="geometry"/>
        </mxCell>

        <mxCell id="gate" value="CueGate at air&#xa;policy · blocks · absolute-drop (FR-63)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="1090" y="110" width="150" height="70" as="geometry"/>
        </mxCell>

        <mxCell id="ndiout" value="NDI out&#xa;SCTE-104 re-emitted&#xa;frame-exact, timecode preserved" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="1280" y="110" width="140" height="70" as="geometry"/>
        </mxCell>

        <mxCell id="e1" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;" edge="1" parent="1" source="src" target="recv"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="e2" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;" edge="1" parent="1" source="recv" target="slot"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="e3" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;" edge="1" parent="1" source="slot" target="fifo"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="e4" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;" edge="1" parent="1" source="fifo" target="pacer"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="e5" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;" edge="1" parent="1" source="pacer" target="gate"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="e6" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;" edge="1" parent="1" source="gate" target="ndiout"><mxGeometry relative="1" as="geometry"/></mxCell>

        <mxCell id="lane2" value="Encode branch (per-channel child process, crash-isolated)" style="text;html=1;fontSize=11;fontStyle=2;align=left;" vertex="1" parent="1">
          <mxGeometry x="40" y="300" width="440" height="20" as="geometry"/>
        </mxCell>

        <mxCell id="ring" value="Encode ring (shared memory)&#xa;frames: aired video+audio, stamped&#xa;with output frame index + timecode&#xa;control: EncodeTriggerRecord sideband&#xa;SINGLE producer — sim OR engine, never both (AIR-149)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="400" y="340" width="300" height="110" as="geometry"/>
        </mxCell>

        <mxCell id="child" value="Airlock.Encode child" style="rounded=1;whiteSpace=wrap;html=1;fillColor=none;strokeColor=#6c8ebf;fontSize=11;fontStyle=2;verticalAlign=top;" vertex="1" parent="1">
          <mxGeometry x="760" y="320" width="560" height="180" as="geometry"/>
        </mxCell>

        <mxCell id="appsrc" value="appsrc&#xa;PTS = content time" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=10;" vertex="1" parent="1">
          <mxGeometry x="780" y="360" width="110" height="50" as="geometry"/>
        </mxCell>
        <mxCell id="x264" value="x264 / NVENC" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=10;" vertex="1" parent="1">
          <mxGeometry x="930" y="360" width="110" height="50" as="geometry"/>
        </mxCell>
        <mxCell id="mux" value="mpegtsmux&#xa;scte-35-pid=500 (0x86)&#xa;pts_adjustment = +1 h base" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=10;" vertex="1" parent="1">
          <mxGeometry x="1080" y="352" width="150" height="66" as="geometry"/>
        </mxCell>
        <mxCell id="srt" value="srtsink&#xa;SRT out" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=10;" vertex="1" parent="1">
          <mxGeometry x="1260" y="360" width="90" height="50" as="geometry"/>
        </mxCell>

        <mxCell id="scte35" value="Scte35Encoder&#xa;splice_insert section, CRC-32&#xa;splicePts = anchorPts + Δframes·dur + P" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;fontSize=10;" vertex="1" parent="1">
          <mxGeometry x="880" y="440" width="230" height="52" as="geometry"/>
