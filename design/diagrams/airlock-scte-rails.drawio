<mxfile host="app.diagrams.net" modified="2026-07-13T00:00:00.000Z" agent="Claude" version="26.2.2" type="device">
  <diagram name="Two metadata rails" id="airlock-scte-rails">
    <mxGraphModel dx="1200" dy="800" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1440" pageHeight="480" math="0" shadow="0">
      <root>
        <mxCell id="0"/>
        <mxCell id="1" parent="0"/>

        <mxCell id="title" value="Two NDI metadata rails cross the delay keyed to the same frame — and meet the same gate at air" style="text;html=1;fontSize=16;fontStyle=1;align=center;verticalAlign=middle;" vertex="1" parent="1">
          <mxGeometry x="220" y="16" width="1000" height="34" as="geometry"/>
        </mxCell>

        <mxCell id="r1lbl" value="Per-frame rail (video_frame.p_metadata) — the cue rides the picture" style="text;html=1;fontSize=11;fontStyle=1;align=left;" vertex="1" parent="1">
          <mxGeometry x="60" y="80" width="480" height="20" as="geometry"/>
        </mxCell>
        <mxCell id="r1a" value="stored INTO&#xa;slot N&#xa;(4 KB region)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=10;" vertex="1" parent="1">
          <mxGeometry x="120" y="110" width="120" height="60" as="geometry"/>
        </mxCell>
        <mxCell id="r1b" value="slot N airs —&#xa;same bytes re-attached&#xa;to the same picture" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=10;" vertex="1" parent="1">
          <mxGeometry x="760" y="110" width="160" height="60" as="geometry"/>
        </mxCell>
        <mxCell id="r1e" value="delay D — frame-exact by construction at any depth, including zero" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;fontSize=10;dashed=1;" edge="1" parent="1" source="r1a" target="r1b">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <mxCell id="r2lbl" value="Standalone rail (metadata frames) — queued, keyed by input frame index" style="text;html=1;fontSize=11;fontStyle=1;align=left;" vertex="1" parent="1">
          <mxGeometry x="60" y="230" width="500" height="20" as="geometry"/>
        </mxCell>
        <mxCell id="r2a" value="tagged with&#xa;input frame index N&#xa;(SCTE VANC only)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=10;" vertex="1" parent="1">
          <mxGeometry x="120" y="260" width="130" height="60" as="geometry"/>
        </mxCell>
        <mxCell id="r2b" value="released when&#xa;frame N airs&#xa;(send_send_metadata)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=10;" vertex="1" parent="1">
          <mxGeometry x="760" y="260" width="160" height="60" as="geometry"/>
        </mxCell>
        <mxCell id="r2e" value="MetadataQueue — AIR-5 release rule" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;fontSize=10;dashed=1;" edge="1" parent="1" source="r2a" target="r2b">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <mxCell id="dump" value="DUMP skip window:&#xa;frame N destroyed → cue dropped&#xa;+ ALARM_SCTE_IN_SKIP&#xa;(a cue for content that never aired must not air)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;fontSize=10;" vertex="1" parent="1">
          <mxGeometry x="420" y="330" width="260" height="80" as="geometry"/>
        </mxCell>
        <mxCell id="dumpe" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;dashed=1;strokeColor=#b85450;exitX=0.5;exitY=0;entryX=0.5;entryY=1;" edge="1" parent="1" source="dump" target="r2e">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <mxCell id="gate" value="CueGate at air&#xa;&#xa;re-emit on the rail of arrival&#xa;104→35 trigger when SRT is fed&#xa;per-type operator blocks (audited, scripts still fire)&#xa;absolute time_type ≠ 0 → DROP after delay (FR-63,&#xa;SCTE 104 §11.5.1 deferred processing)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=10;align=left;spacingLeft=8;" vertex="1" parent="1">
          <mxGeometry x="1000" y="110" width="300" height="130" as="geometry"/>
        </mxCell>
        <mxCell id="g1" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;" edge="1" parent="1" source="r1b" target="gate"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="g2" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;exitX=1;exitY=0.5;entryX=0.5;entryY=1;" edge="1" parent="1" source="r2b" target="gate"><mxGeometry relative="1" as="geometry"/></mxCell>

        <mxCell id="scripts" value="scripts: scteReceived at arrival · scteAired at air —&#xa;the gap between them IS the delay: automation learns about a break D seconds before the audience" style="text;html=1;fontSize=10;fontStyle=2;align=left;fillColor=#f5f5f5;strokeColor=#999999;rounded=1;verticalAlign=middle;spacing=6;" vertex="1" parent="1">
          <mxGeometry x="1000" y="280" width="380" height="50" as="geometry"/>
        </mxCell>

        <mxCell id="decode" value="Decode is inline on the engine thread: vancData = base64 of 8-bit user-data words → span scan + preallocated-buffer decode, sub-µs, zero allocation" style="text;html=1;fontSize=10;fontStyle=2;align=left;fillColor=#f5f5f5;strokeColor=#999999;rounded=1;verticalAlign=middle;spacing=6;" vertex="1" parent="1">
          <mxGeometry x="60" y="432" width="620" height="40" as="geometry"/>
        </mxCell>
