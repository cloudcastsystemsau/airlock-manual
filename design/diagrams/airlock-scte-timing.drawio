<mxfile host="app.diagrams.net" modified="2026-07-13T00:00:00.000Z" agent="Claude" version="26.2.2" type="device">
  <diagram name="Cue timing" id="airlock-scte-timing">
    <mxGraphModel dx="1200" dy="800" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1440" pageHeight="460" math="0" shadow="0">
      <root>
        <mxCell id="0"/>
        <mxCell id="1" parent="0"/>

        <mxCell id="title" value="One cue, two rails, one instant — measured: notice 4.4 s vs the SCTE 35 §9.9.2.1 4 s floor, splice-instant error +0.0 ms" style="text;html=1;fontSize=16;fontStyle=1;align=center;verticalAlign=middle;" vertex="1" parent="1">
          <mxGeometry x="170" y="16" width="1100" height="34" as="geometry"/>
        </mxCell>

        <mxCell id="axis" style="endArrow=classic;html=1;strokeColor=#999999;" edge="1" parent="1">
          <mxGeometry relative="1" as="geometry"><mxPoint x="80" y="180" as="sourcePoint"/><mxPoint x="1380" y="180" as="targetPoint"/></mxGeometry>
        </mxCell>
        <mxCell id="axlbl" value="time" style="text;html=1;fontSize=10;fontStyle=2;" vertex="1" parent="1">
          <mxGeometry x="1340" y="150" width="40" height="20" as="geometry"/>
        </mxCell>

        <mxCell id="m1" style="endArrow=none;html=1;strokeColor=#6c8ebf;strokeWidth=2;" edge="1" parent="1">
          <mxGeometry relative="1" as="geometry"><mxPoint x="200" y="160" as="sourcePoint"/><mxPoint x="200" y="200" as="targetPoint"/></mxGeometry>
        </mxCell>
        <mxCell id="m1t" value="T" style="text;html=1;fontSize=13;fontStyle=1;align=center;" vertex="1" parent="1">
          <mxGeometry x="180" y="130" width="40" height="20" as="geometry"/>
        </mxCell>
        <mxCell id="m1l" value="cue arrives on frame N&#xa;(timecode Tc) — scteReceived fires,&#xa;cue stored with the slot" style="text;html=1;fontSize=10;align=center;" vertex="1" parent="1">
          <mxGeometry x="90" y="210" width="220" height="46" as="geometry"/>
        </mxCell>

        <mxCell id="m2" style="endArrow=none;html=1;strokeColor=#82b366;strokeWidth=2;" edge="1" parent="1">
          <mxGeometry relative="1" as="geometry"><mxPoint x="760" y="160" as="sourcePoint"/><mxPoint x="760" y="200" as="targetPoint"/></mxGeometry>
        </mxCell>
        <mxCell id="m2t" value="T + D" style="text;html=1;fontSize=13;fontStyle=1;align=center;" vertex="1" parent="1">
          <mxGeometry x="730" y="130" width="60" height="20" as="geometry"/>
        </mxCell>
        <mxCell id="m2l" value="cue AIRS — same timecode Tc out (frame-exact)&#xa;scteAired fires · SCTE-104 re-emitted on NDI&#xa;SCTE-35 section injected into the TS mux" style="text;html=1;fontSize=10;align=center;" vertex="1" parent="1">
          <mxGeometry x="620" y="210" width="280" height="46" as="geometry"/>
        </mxCell>

        <mxCell id="m3" style="endArrow=none;html=1;strokeColor=#b85450;strokeWidth=2;" edge="1" parent="1">
          <mxGeometry relative="1" as="geometry"><mxPoint x="1240" y="160" as="sourcePoint"/><mxPoint x="1240" y="200" as="targetPoint"/></mxGeometry>
        </mxCell>
        <mxCell id="m3t" value="T + D + P" style="text;html=1;fontSize=13;fontStyle=1;align=center;" vertex="1" parent="1">
          <mxGeometry x="1195" y="130" width="90" height="20" as="geometry"/>
        </mxCell>
        <mxCell id="m3l" value="SPLICE POINT&#xa;both rails name this same instant —&#xa;the downstream cuts here" style="text;html=1;fontSize=10;align=center;" vertex="1" parent="1">
          <mxGeometry x="1120" y="210" width="240" height="46" as="geometry"/>
        </mxCell>

        <mxCell id="spanD" value="delay D (8.00 s measured)" style="endArrow=classic;startArrow=classic;html=1;strokeColor=#82b366;fontSize=10;" edge="1" parent="1">
          <mxGeometry relative="1" as="geometry"><mxPoint x="205" y="120" as="sourcePoint"/><mxPoint x="755" y="120" as="targetPoint"/></mxGeometry>
        </mxCell>
        <mxCell id="spanP" value="pre-roll P — the upstream's own, never the 4 s template floor" style="endArrow=classic;startArrow=classic;html=1;strokeColor=#b85450;fontSize=10;" edge="1" parent="1">
          <mxGeometry relative="1" as="geometry"><mxPoint x="765" y="120" as="sourcePoint"/><mxPoint x="1235" y="120" as="targetPoint"/></mxGeometry>
        </mxCell>

        <mxCell id="ts" value="TS rail arithmetic (control latency cancels out — both sides are frame indices from one counter):&#xa;&#xa;splicePts = anchorPts + (airedFrame − anchorFrame) × frameDuration + P&#xa;wire value = splicePts + pts_adjustment (mpegtsmux adds its 1-hour clock base = 324,000,000 ticks; SCTE 35 §9.6: effective time = pts_time + pts_adjustment)&#xa;notice at the receiver = P + mux position offset ≥ the 4 s arrival floor (§9.9.2.1, one-sided — earlier is conformant)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#999999;fontSize=10;align=left;spacingLeft=10;spacingTop=4;" vertex="1" parent="1">
          <mxGeometry x="90" y="290" width="1270" height="110" as="geometry"/>
        </mxCell>
      </root>
    </mxGraphModel>
