          <mxGeometry x="30" y="80" width="150" height="90" as="geometry"/>
        </mxCell>

        <mxCell id="recv" value="Data receiver&#xa;&quot;automation&quot;&#xa;tcpServer :5599 (AIR-82)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=10;" vertex="1" parent="1">
