        <mxCell id="arm" value="script arm-break (JS)&#xa;trigger: dataReceived&#xa;&#xa;reads live depth: air.Depth(3)/fps = 7.94 s&#xa;out = (15 + 7.94 − 4) s → air.After(18940, &quot;brk-out&quot;)&#xa;in = (15 + 7.94 + 20 − 4) s → air.After(38940, &quot;brk-in&quot;)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=10;align=left;spacingLeft=8;" vertex="1" parent="1">
          <mxGeometry x="440" y="72" width="330" height="106" as="geometry"/>
        </mxCell>

