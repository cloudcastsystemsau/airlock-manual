        <mxCell id="title" value="Receiver-driven ad break (AIR-151) — passthrough SCTE blocked; a data message originates the cues, delay-aware" style="text;html=1;fontSize=16;fontStyle=1;align=center;verticalAlign=middle;" vertex="1" parent="1">
