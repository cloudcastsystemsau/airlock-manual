        <mxCell id="note" value="Passthrough SCTE is blocked at CueGate (policy / Block SCTE) — blocked cues still audit and fire scripts, but never leave the box. Script-originated triggers use the separate origination path, unaffected by the blocks: that pairing is the point." style="rounded=1;whiteSpace=wrap;html=1;fontSize=10;fontStyle=2;align=left;fillColor=#f5f5f5;strokeColor=#999999;verticalAlign=middle;spacing=8;" vertex="1" parent="1">
